# 3-rbac/terraform.tfvars.example

export TF_VAR_proxy_address="teleport.example.com"
export TF_VAR_okta_metadata_url="https://XXXXX.okta.com/app/XXXXXXXX/sso/saml/metadata"

# Static access list membership — Terraform-managed (no SCIM required).
# Add user emails for each persona tier.
#
# base-user is assigned automatically via the SAML connector (Everyone group).
#
# devs        → dev-access, dev-auto-access, dev-requester
# senior_devs → platform-dev-access, dev-auto-access, senior-dev-requester
# engineers   → platform-dev-access, dev-auto-access, prod-readonly-access,
#               dev-reviewer, prod-requester, prod-reviewer, editor, auditor

export TF_VAR_devs='["bob@example.com"]'

export TF_VAR_senior_devs='["alice@example.com"]'

export TF_VAR_engineers='["admin@example.com"]'

# Agent managed updates — set to "disabled" to pin versions manually
export TF_VAR_autoupdate_mode="enabled"
