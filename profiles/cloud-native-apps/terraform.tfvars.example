export TF_VAR_proxy_address="teleport.example.com"
export TF_VAR_user="engineer@example.com"
export TF_VAR_teleport_version="18.0.0"
export TF_VAR_region="us-east-2"
export TF_VAR_env="dev"
export TF_VAR_team="platform"

# IAM role ARNs the AWS Console app is allowed to assume.
# Leave empty to skip AWS Console federation: console_role_arns = []
export TF_VAR_console_role_arns='["arn:aws:iam::123456789012:role/ReadOnly", "arn:aws:iam::123456789012:role/PowerUser"]'
