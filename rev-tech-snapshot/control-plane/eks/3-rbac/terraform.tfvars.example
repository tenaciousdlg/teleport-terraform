# 3-rbac/terraform.tfvars.example

export TF_VAR_proxy_address="teleportdemo.com"
export TF_VAR_region="us-east-2"

# Okta SAML connector (primary / integrator tenant)
export TF_VAR_okta_metadata_url="https://integrator-XXXXX.okta.com/app/XXXXXXXX/sso/saml/metadata"

# Okta Preview connector (optional — set enable_okta_preview = true to activate)
export TF_VAR_enable_okta_preview="false"
export TF_VAR_okta_preview_metadata_url=""

# Team label used in role label matchers
# dev_team  — matches resources tagged team=<dev_team>
# prod_team — matches resources tagged team=<prod_team>
export TF_VAR_dev_team="dev"
export TF_VAR_prod_team="platform"
